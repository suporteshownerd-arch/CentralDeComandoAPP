# Central de Comando DPSP - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# ============================================
# SEGURANÇA
# ============================================

# Chave mestra para descriptografia dos CSVs (Gerada com Fernet.generate_key())
MASTER_KEY=

# ============================================
# GOOGLE SHEETS
# ============================================

# Credenciais da Service Account (JSON completo)
# GCP_SERVICE_ACCOUNT='{"type":"service_account","project_id":...}'
GCP_SERVICE_ACCOUNT=

# IDs das planilhas do Google Sheets
SHEETS_ID_AEXEC=
SHEETS_ID_GCRISES=

# ============================================
# CONFIGURAÇÕES
# ============================================

# Ambiente (development/production)
APP_ENV=development

# Porta do servidor (padrão: 8501)
APP_PORT=8501

# ============================================
# EXEMPLO DE PREENCHIMENTO
# ============================================

# MASTER_KEY=abc123... (chave Fernet gerada)
# SHEETS_ID_AEXEC=1Abc123... (ID da planilha Alertas Executivos)
# SHEETS_ID_GCRISES=1Xyz789... (ID da planilha Gestão de Crises)
